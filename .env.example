# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_ID=your_telegram_user_id_here

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Server
PORT=8080
SESSION_SECRET=your_secure_random_secret_here

# Public URL — set this to your Railway deployment URL after deploying
# Example: https://bingo-bot-production.up.railway.app
WEBAPP_URL=https://your-app.up.railway.app
